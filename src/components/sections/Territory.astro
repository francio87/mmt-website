---
import { Image } from 'astro:assets';
import { hero } from '../../data/images.js';
const { content } = Astro.props;
---
<section class="territory section" id="territorio" aria-labelledby="territorio-title"><Image class="territory-background" src={hero} widths={[960, 1440, 2000]} sizes="100vw" alt="" loading="lazy" decoding="async" /><div class="territory-inner reveal"><p class="eyebrow">{content.kicker}</p><h2 id="territorio-title">{content.title}</h2><p>{content.text}</p></div></section>
