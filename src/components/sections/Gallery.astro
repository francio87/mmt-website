---
import { Image } from 'astro:assets';
import { galleryImages } from '../../data/images.js';
const { content } = Astro.props;
---
<section class="gallery section" id="galleria" aria-labelledby="galleria-title"><div class="gallery-heading reveal"><p class="eyebrow dark">{content.kicker}</p><h2 id="galleria-title">{content.title}</h2><p>{content.description}</p></div><div class="gallery-grid" aria-label={content.title}>{content.items.map((item, index) => <figure class:list={['gallery-item', item.className, 'reveal']}><button class="gallery-button" type="button" data-lightbox-index={index} aria-label={`${content.title}: ${item.title}`} data-analytics-event="gallery_open" data-analytics-item={index + 1}><Image src={galleryImages[index]} widths={[480, 768, 1200]} sizes="(min-width: 1100px) 33vw, (min-width: 640px) 50vw, 100vw" alt={item.alt} loading="lazy" decoding="async" /></button><figcaption>{item.title} <small>{item.credit}</small></figcaption></figure>)}</div></section>
