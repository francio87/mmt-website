---
const { content } = Astro.props;
---
<section class="visit section" id="visita" aria-labelledby="visita-title"><div class="visit-header reveal"><p class="eyebrow dark">{content.kicker}</p><h2 id="visita-title">{content.title}</h2></div><div class="visit-layout">{content.cards.map((card) => <article class:list={['visit-note', { wide: card.wide }, 'reveal']}><span class="visit-label">{card.label}</span><h3>{card.title}</h3><p>{card.text}</p><ul class="info-list">{card.facts.map((fact) => <li>{fact}</li>)}</ul></article>)}</div></section>
