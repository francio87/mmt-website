---
const { content } = Astro.props;
const icons = [
  '<path d="M7 39c7-17 16-28 27-34 2 11 5 21 10 34H7Z"/><path d="M12 39c5-4 10-6 16-5 5 1 9 4 15 3"/>',
  '<path d="M35 15c-4-6-15-7-21-1-7 7-4 19 6 22 9 3 17-5 14-13-2-6-10-7-14-3-4 4-2 10 3 12"/><circle cx="30" cy="30" r="3"/>',
  '<path d="M8 35c7-9 13-4 20-13 5-6 7-12 12-15"/><path d="M9 41c7-6 14-2 21-8 5-4 7-9 10-12"/><circle cx="14" cy="35" r="2"/><circle cx="34" cy="13" r="2"/>',
  '<path d="M12 8v32"/><path d="M36 8v32"/><path d="M12 16c8 5 16 5 24 0"/><path d="M12 31c8-5 16-5 24 0"/><circle cx="24" cy="24" r="5"/>'
];
---
<section class="geology section" id="geologia" aria-labelledby="geologia-title"><div class="geology-heading reveal"><p class="eyebrow dark">{content.kicker}</p><h2 id="geologia-title">{content.title}</h2><p>{content.description}</p></div><div class="geology-grid">{content.cards.map(([title, text], index) => <article class="geology-card reveal"><span class="geology-icon" aria-hidden="true"><svg viewBox="0 0 48 48" focusable="false" set:html={icons[index]} /></span><h3>{title}</h3><p>{text}</p></article>)}</div></section>
