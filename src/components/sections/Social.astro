---
const { content } = Astro.props;
---
<section class="social section" id="social" aria-labelledby="social-title"><div class="social-copy reveal"><p class="eyebrow dark">{content.kicker}</p><h2 id="social-title">{content.title}</h2><p>{content.before} <a class="social-link" href="https://www.instagram.com/marmittedeigiganti/" target="_blank" rel="noopener noreferrer"><strong>@marmittedeigiganti</strong></a> {content.middle} <a class="social-link" href="https://www.instagram.com/explore/tags/marmittedeigiganti/" target="_blank" rel="noopener noreferrer"><strong>#marmittedeigiganti</strong></a>{content.after}</p></div></section>
