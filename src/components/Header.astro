---
const { lang, nav, policy = false } = Astro.props;
const home = `/${lang}/`;
const alternate = lang === 'it' ? 'en' : 'it';
const labels = lang === 'en' ? { menu: 'Open navigation menu', navigation: 'Main navigation', home: 'Marmitte dei Giganti, back to home', alternate: 'Switch to Italian' } : { menu: 'Apri menu di navigazione', navigation: 'Navigazione principale', home: 'Marmitte dei Giganti, torna alla home', alternate: 'Switch to English' };
---
<header class:list={['site-header', { 'is-scrolled': policy }]} data-header>
  <a class="brand" href={home} aria-label={labels.home}><span class="brand-mark" aria-hidden="true"><svg viewBox="0 0 64 64" focusable="false"><path d="M13 53c7-8 10-16 8-25-2-9 2-17 11-22" /><path d="M52 11c-9 6-13 14-10 25 3 10-3 18-16 22" /><path d="M25 55c8-7 10-14 6-21-4-8 0-15 9-20" /><path d="M16 43c7-3 15-2 22 4" /><circle cx="39" cy="31" r="5" /></svg></span><span class="brand-text">Marmitte dei Giganti</span></a>
  <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav" data-menu-toggle><span class="sr-only">{labels.menu}</span><span aria-hidden="true"></span><span aria-hidden="true"></span><span aria-hidden="true"></span></button>
  <nav class="site-nav" id="site-nav" aria-label={labels.navigation} data-nav>{nav.map(([id, label]) => <a href={`${home}#${id}`}>{label}</a>)}</nav>
  <a class="lang-toggle" href={`/${alternate}/`} aria-label={labels.alternate} data-analytics-event="language_switch" data-analytics-language={alternate}><span class="lang-flag" aria-hidden="true">{alternate === 'en' ? '🇬🇧' : '🇮🇹'}</span><span>{alternate.toUpperCase()}</span></a>
</header>
